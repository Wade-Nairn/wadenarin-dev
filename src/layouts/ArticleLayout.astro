---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  category: string;
  date: string;
}

const { title, description, category, date } = Astro.props;

const formattedDate = new Date(date).toLocaleDateString('en-AU', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} — Wade Nairn`} description={description} ogType="article">
  <div class="article-wrap">
    <div class="article-header">
      <a href="/articles" class="back-link">← All articles</a>

      <div class="article-meta">
        <span class="article-category">{category}</span>
        <time datetime={date}>{formattedDate}</time>
      </div>

      <p class="article-description">{description}</p>
    </div>

    <hr class="divider" />

    <div class="prose">
      <slot />
    </div>

    <div class="article-footer">
      <a href="/articles" class="back-link">← All articles</a>
    </div>
  </div>
</BaseLayout>

<style>
  .article-wrap {
    background: #0d0d0d;
    min-height: 100vh;
    padding: 20vh 4rem 15vh;
    max-width: 720px;
    opacity: 0;
    animation: fade-in 0.6s ease-out 1s forwards;
  }

  @keyframes fade-in { to { opacity: 1; } }

  .article-header { margin-bottom: 3rem; }

  .back-link {
    display: inline-block;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.45);
    text-decoration: none;
    margin-bottom: 2.5rem;
    transition: color 0.15s ease;
  }

  .back-link:hover { color: rgba(255, 255, 255, 0.9); }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.5);
  }

  .article-category { color: rgba(255, 255, 255, 0.5); }

  h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    color: white;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 1.25rem;
  }

  .article-description {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.7;
    margin: 0;
  }

  .divider {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    margin: 3rem 0;
  }

  /* Prose body */
  .prose { color: rgba(255, 255, 255, 0.75); line-height: 1.8; }

  .prose :global(h1) {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 700;
    color: white;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 1.25rem;
  }

  .prose :global(h2) {
    font-size: 1.5rem;
    font-weight: 600;
    color: white;
    margin: 3rem 0 1rem;
  }

  .prose :global(h3) {
    font-size: 1.2rem;
    font-weight: 600;
    color: white;
    margin: 2rem 0 0.75rem;
  }

  .prose :global(p) {
    margin: 0 0 1.25rem;
    color: rgba(255, 255, 255, 0.75);
  }

  .prose :global(a) {
    color: rgba(255, 255, 255, 0.9);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(255, 255, 255, 0.25);
    transition: text-decoration-color 0.15s ease;
  }

  .prose :global(a:hover) { text-decoration-color: rgba(255, 255, 255, 0.7); }

  .prose :global(strong) { color: white; font-weight: 600; }

  .prose :global(code) {
    font-size: 0.875em;
    color: rgba(255, 255, 255, 0.85);
    background: rgba(255, 255, 255, 0.07);
    padding: 0.15em 0.4em;
    border-radius: 4px;
  }

  .prose :global(pre) {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 6px;
    padding: 1.25rem;
    overflow-x: auto;
    margin: 1.5rem 0;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.875rem;
    color: rgba(255, 255, 255, 0.8);
  }

  .prose :global(blockquote) {
    border-left: 2px solid rgba(255, 255, 255, 0.2);
    padding-left: 1.25rem;
    color: rgba(255, 255, 255, 0.55);
    margin: 1.5rem 0;
    font-style: italic;
  }

  .prose :global(ul), .prose :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.25rem;
    color: rgba(255, 255, 255, 0.75);
  }

  .prose :global(li) { margin-bottom: 0.4rem; }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    margin: 2.5rem 0;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
    margin: 1.5rem 0;
  }

  .prose :global(th) {
    color: rgba(255, 255, 255, 0.7);
    font-weight: 600;
    text-align: left;
    padding: 0.6rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .prose :global(td) {
    color: rgba(255, 255, 255, 0.6);
    padding: 0.6rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .article-footer {
    margin-top: 5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  @media (max-width: 640px) {
    .article-wrap { padding: 15vh 3rem 10vh; }
  }

  @media (prefers-reduced-motion: reduce) {
    .article-wrap { animation: none; opacity: 1; }
  }
</style>
